{
  "info": {
    "name": "Smart Recruitment Platform - Public API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public Jobs",
      "item": [
        {
          "name": "Public Jobs Listing",
          "request": { "method": "GET", "description": "Public API: unauthenticated users browse published jobs.", "url": "{{base_url}}/jobs" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('jobs list succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        },
        {
          "name": "Public Job Details",
          "request": { "method": "GET", "description": "Public API: unauthenticated users view one published job.", "url": "{{base_url}}/jobs/{{job_id}}" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('job details succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Public Skills",
      "item": [
        {
          "name": "Public Skills",
          "request": { "method": "GET", "description": "Public API: unauthenticated users retrieve skill catalog values.", "url": "{{base_url}}/skills" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('skills list succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Register/Login",
      "item": [
        {
          "name": "Register Job Seeker",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Public API: creates a job seeker account for Mobile App users.",
            "url": "{{base_url}}/auth/register/job-seeker",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Applicant\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('register succeeds', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        },
        {
          "name": "Register Employer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Public API: creates an employer account for Web Dashboard users.",
            "url": "{{base_url}}/auth/register/employer",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Employer User\",\n  \"email\": \"employer@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"company_name\": \"Acme Hiring Co.\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('register succeeds', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Public API: logs in Mobile, Web, or Admin users.",
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('login succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    }
  ]
}
