{
  "info": {
    "name": "Smart Recruitment Platform - Admin Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }] },
  "item": [
    {
      "name": "Auth - Admin",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Admin Dashboard: logs in an administrator.",
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('login succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "List Users", "request": { "method": "GET", "description": "Admin Dashboard: lists platform users.", "url": "{{base_url}}/admin/users" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('users loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Admin Dashboard: activates, suspends, or reviews a user account.",
            "url": "{{base_url}}/admin/users/{{user_id}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"active\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status updated', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Companies Approval",
      "item": [
        { "name": "List Companies", "request": { "method": "GET", "description": "Admin Dashboard: lists companies pending or completed approval.", "url": "{{base_url}}/admin/companies" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('companies loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        { "name": "Approve Company", "request": { "method": "PATCH", "description": "Admin Dashboard: approves an employer company.", "url": "{{base_url}}/admin/companies/{{company_id}}/approve" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('company approved', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        { "name": "Reject Company", "request": { "method": "PATCH", "description": "Admin Dashboard: rejects an employer company.", "url": "{{base_url}}/admin/companies/{{company_id}}/reject" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('company rejected', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    },
    {
      "name": "Skills",
      "item": [
        { "name": "List Admin Skills", "request": { "method": "GET", "description": "Admin Dashboard: manages the skills catalog used by parsing and matching.", "url": "{{base_url}}/admin/skills" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('skills loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        {
          "name": "Create Skill",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Admin Dashboard: creates a catalog skill.",
            "url": "{{base_url}}/admin/skills",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Laravel\",\n  \"slug\": \"laravel\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('skill created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        }
      ]
    },
    {
      "name": "Tests",
      "item": [
        { "name": "List Admin Tests", "request": { "method": "GET", "description": "Admin Dashboard: lists test catalog entries.", "url": "{{base_url}}/admin/tests" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('tests loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        {
          "name": "Create Admin Test",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Admin Dashboard: creates an assessment test.",
            "url": "{{base_url}}/admin/tests",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Laravel Basics\",\n  \"description\": \"Backend screening test.\",\n  \"duration_minutes\": 30\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('test created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        }
      ]
    },
    {
      "name": "Reports/Audit",
      "item": [
        { "name": "Admin Users Audit Source", "request": { "method": "GET", "description": "Admin Dashboard: uses existing user listing as an audit source until dedicated reports endpoints are added.", "url": "{{base_url}}/admin/users" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('audit source loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    }
  ]
}
