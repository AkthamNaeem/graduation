{
  "info": {
    "name": "Smart Recruitment Platform - Mobile App",
    "description": "Mobile consumer collection. Includes public discovery APIs and authenticated job seeker APIs only. TODO: add dedicated saved-jobs endpoints here if the backend later supports them.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{job_seeker_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "01 Auth - Job Seeker",
      "item": [
        {
          "name": "Register Job Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Mobile App / Job Seeker: create a job seeker account. Requires accepted terms; optional phone is saved on the job seeker profile.",
            "url": "{{base_url}}/auth/register/job-seeker",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Applicant\",\n  \"email\": \"{{job_seeker_email}}\",\n  \"phone\": \"+1 555 0100\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"terms_accepted\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register job seeker response', () => pm.expect(pm.response.code).to.be.oneOf([201, 422]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Job Seeker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Mobile App / Job Seeker: login and stores the returned Sanctum token in {{job_seeker_token}}.",
            "url": "{{base_url}}/auth/login",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{job_seeker_email}}\",\n  \"password\": \"password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login response', () => pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 422]));",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.token) pm.environment.set('job_seeker_token', json.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Mobile App / Job Seeker: fetch the authenticated user and nested job seeker profile.",
            "url": "{{base_url}}/auth/me",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{job_seeker_token}}",
                  "type": "string"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('me response', () => pm.expect(pm.response.code).to.be.oneOf([200, 401]));"
                ]
              }
            }
          ]
        },
        {
          "name": "Forgot Password",
