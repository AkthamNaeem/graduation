              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/cv/{{cv_id}}/parsed",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cv",
                "{{cv_id}}",
