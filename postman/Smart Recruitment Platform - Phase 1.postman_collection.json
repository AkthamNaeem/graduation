{
  "info": {
    "_postman_id": "0a0d9b71-9f72-4609-94ef-c2fc7be245de",
    "name": "Smart Recruitment Platform - Phase 1",
    "description": "Phase 1 authentication endpoints for the Smart Recruitment Platform API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register Job Seeker",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Applicant\",\n  \"email\": \"jane.applicant@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register/job-seeker",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register",
            "job-seeker"
          ]
        },
        "description": "Create a job seeker account and its profile."
      },
      "response": []
    },
    {
      "name": "Register Employer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Evan Employer\",\n  \"email\": \"evan.employer@example.com\",\n  \"company_name\": \"Talent Forge\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register/employer",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register",
            "employer"
          ]
        },
        "description": "Create an employer account, company, and employer profile."
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const response = pm.response.json();",
              "if (response.success && response.data && response.data.token) {",
              "    pm.collectionVariables.set('token', response.data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"jobseeker@smartrecruitment.test\",\n  \"password\": \"password\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Authenticate a user and store the bearer token for the protected requests."
      },
      "response": []
    },
    {
      "name": "Me",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        },
        "description": "Retrieve the authenticated user with the nested role-specific profile."
      },
      "response": []
    },
    {
      "name": "Logout",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        },
        "description": "Revoke the current bearer token."
      },
      "response": []
    }
  ]
}
