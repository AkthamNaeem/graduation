{
  "info": {
    "name": "Smart Recruitment Platform - Web Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{employer_token}}", "type": "string" }] },
  "item": [
    {
      "name": "Auth - Employer",
      "item": [
        {
          "name": "Login Employer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Web Dashboard: logs in an employer.",
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"employer@example.com\",\n  \"password\": \"password\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('login succeeds', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Company Profile",
      "item": [
        { "name": "Get Company", "request": { "method": "GET", "description": "Web Dashboard: loads the employer company profile.", "url": "{{base_url}}/company" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('company loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Web Dashboard: updates company profile data.",
            "url": "{{base_url}}/company",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Talent\",\n  \"industry\": \"Recruitment Technology\",\n  \"website\": \"https://acme.example.com\",\n  \"location\": \"Remote\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('company updated', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Employer Profile",
      "item": [
        { "name": "Get Employer Profile", "request": { "method": "GET", "description": "Web Dashboard: loads the authenticated employer profile.", "url": "{{base_url}}/employer/profile" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('profile loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    },
    {
      "name": "Job Management",
      "item": [
        {
          "name": "Create Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Web Dashboard: creates a draft job posting.",
            "url": "{{base_url}}/jobs",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Backend Developer\",\n  \"description\": \"Build Laravel APIs.\",\n  \"location\": \"Remote\",\n  \"employment_type\": \"full_time\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('job created', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        },
        { "name": "My Jobs", "request": { "method": "GET", "description": "Web Dashboard: lists employer-owned jobs.", "url": "{{base_url}}/jobs/my" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('jobs loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        { "name": "Publish Job", "request": { "method": "POST", "description": "Web Dashboard: publishes a draft job.", "url": "{{base_url}}/jobs/{{job_id}}/publish" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('job published', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    },
    {
      "name": "Applications Pipeline",
      "item": [
        { "name": "Applications By Job", "request": { "method": "GET", "description": "Web Dashboard: lists applications for one employer job.", "url": "{{base_url}}/jobs/{{job_id}}/applications" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('applications loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        {
          "name": "Change Application Status",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Web Dashboard: moves a candidate through the application pipeline.",
            "url": "{{base_url}}/applications/{{application_id}}/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"shortlisted\",\n  \"notes\": \"Good backend experience.\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status changed', () => pm.expect(pm.response.code).to.eql(200));"] } }]
        }
      ]
    },
    {
      "name": "Candidate Review",
      "item": [
        { "name": "Ranked Candidates", "request": { "method": "GET", "description": "Web Dashboard: reviews ranked candidates for a job.", "url": "{{base_url}}/jobs/{{job_id}}/candidates/ranked" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('candidates loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    },
    {
      "name": "Tests Management",
      "item": [
        { "name": "List Tests", "request": { "method": "GET", "description": "Web Dashboard: lists employer/admin test catalog entries.", "url": "{{base_url}}/tests" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('tests loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] },
        { "name": "Assign Test", "request": { "method": "POST", "description": "Web Dashboard: assigns a test to a job application.", "url": "{{base_url}}/applications/{{application_id}}/assign-test" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('test assigned', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }] }
      ]
    },
    {
      "name": "Interviews Management",
      "item": [
        {
          "name": "Schedule Interview",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "description": "Web Dashboard: schedules an interview for an application.",
            "url": "{{base_url}}/applications/{{application_id}}/interviews",
            "body": { "mode": "raw", "raw": "{\n  \"scheduled_at\": \"2026-07-10T10:00:00Z\",\n  \"location\": \"Google Meet\",\n  \"notes\": \"Technical interview\"\n}", "options": { "raw": { "language": "json" } } }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('interview scheduled', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"] } }]
        }
      ]
    },
    {
      "name": "Final Decisions",
      "item": [
        { "name": "Close Job", "request": { "method": "POST", "description": "Web Dashboard: closes a job after final decisions.", "url": "{{base_url}}/jobs/{{job_id}}/close" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('job closed', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "Notifications", "request": { "method": "GET", "description": "Web Dashboard: lists employer notifications.", "url": "{{base_url}}/notifications" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('notifications loaded', () => pm.expect(pm.response.code).to.eql(200));"] } }] }
      ]
    }
  ]
}
